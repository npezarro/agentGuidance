# Discord webhook URL for posting daily TLDR reports to #tldr
# Get from: Discord > Channel Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Discord webhook URL for posting daily work logs to #daily-logs
# This is a work-focused summary (no health/ops data). Optional — if unset, only #tldr is posted.
DISCORD_DAILY_LOGS_WEBHOOK_URL=

# Optional: override channel for TLDR reports (uses webhook's default channel if unset)
# DISCORD_TLDR_CHANNEL_ID=
